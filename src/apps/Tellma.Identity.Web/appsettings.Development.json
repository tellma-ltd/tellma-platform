{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "TellmaIdentity": {
    "Issuer": "https://localhost:7051",
    "ConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=TellmaIdentity;Trusted_Connection=True;TrustServerCertificate=True",
    "Keys": {
      "Signing": { "Source": "DevelopmentSelfSigned" },
      "Encryption": { "Source": "DevelopmentSelfSigned" }
    },
    "Development": {
      "AllowDevelopmentCertificates": true,
      "AllowInsecureHttp": true,
      "UseEmailSink": true
    },
    "Seed": {
      "ApplyMigrations": true,
      "DevAdmin": { "Enabled": true }
    }
  }
}
