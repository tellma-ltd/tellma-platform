{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "TellmaIdentity": {
    "Mode": "Standalone",
    "Issuer": null,
    "ConnectionString": null,
    "Keys": {
      "Signing": { "Source": "None" },
      "Encryption": { "Source": "None" }
    }
  }
}
