@page
@model Tellma.Identity.Areas.Identity.Pages.Account.ForgotPasswordModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> L
@{
    ViewData["Title"] = L["ForgotPassword"].Value;
}

<h1 class="tl-title">@L["ForgotPassword"]</h1>

@if (Model.Submitted)
{
    <p class="tl-status">@L["ResetLinkSent"]</p>
}
else
{
    <p class="tl-muted">@L["ForgotPasswordPrompt"]</p>
    <form method="post">
        <div class="tl-field">
            <label class="tl-label" for="email">@L["Email"]</label>
            <input class="tl-input" id="email" name="Email" type="email" inputmode="email" required />
        </div>
        <button class="tl-button tl-button-primary" type="submit">@L["SendResetLink"]</button>
    </form>
}
