{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "core-ui": {
      "projectType": "library",
      "root": "projects/core/tellma-core-ui",
      "sourceRoot": "projects/core/tellma-core-ui/src",
      "prefix": "tm",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/core/tellma-core-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/core/tellma-core-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/core/tellma-core-ui/tsconfig.spec.json"
          }
        }
      }
    },
    "core-ui-tokens": {
      "projectType": "library",
      "root": "projects/core/tellma-core-ui-tokens",
      "sourceRoot": "projects/core/tellma-core-ui-tokens/src",
      "prefix": "tm",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/core/tellma-core-ui-tokens/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/core/tellma-core-ui-tokens/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/core/tellma-core-ui-tokens/tsconfig.spec.json"
          }
        }
      }
    },
    "core-ui-testing": {
      "projectType": "library",
      "root": "projects/core/tellma-core-ui-testing",
      "sourceRoot": "projects/core/tellma-core-ui-testing/src",
      "prefix": "tm",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/core/tellma-core-ui-testing/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/core/tellma-core-ui-testing/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/core/tellma-core-ui-testing/tsconfig.spec.json"
          }
        }
      }
    },
    "locale-ar": {
      "projectType": "library",
      "root": "projects/locale/tellma-locale-ar",
      "sourceRoot": "projects/locale/tellma-locale-ar/src",
      "prefix": "tm",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/locale/tellma-locale-ar/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/locale/tellma-locale-ar/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/locale/tellma-locale-ar/tsconfig.spec.json"
          }
        }
      }
    },
    "sandbox": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/internal/sandbox",
      "sourceRoot": "projects/internal/sandbox/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/internal/sandbox/src/main.ts",
            "tsConfig": "projects/internal/sandbox/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/internal/sandbox/public"
              }
            ],
            "styles": [
              "projects/core/tellma-core-ui-tokens/css/tellma-default.css",
              "projects/internal/sandbox/src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "storybook": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "sandbox:build:production"
            },
            "development": {
              "buildTarget": "sandbox:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "sandbox:build:storybook",
            "compodoc": false
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "sandbox:build:storybook",
            "compodoc": false,
            "outputDir": ".artifacts/storybook"
          }
        }
      }
    }
  }
}
