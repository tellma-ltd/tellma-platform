{
  "AllowedHosts": "*",
  "TellmaIdentity": {
    "Mode": "InProc",
    "PathBase": "/id",
    "Issuer": "http://localhost/id",
    "ConnectionString": "Server=overridden-by-tests;Database=overridden-by-tests;Encrypt=False",
    "Keys": {
      "Signing": { "Source": "DevelopmentSelfSigned" },
      "Encryption": { "Source": "DevelopmentSelfSigned" }
    },
    "Development": {
      "AllowDevelopmentCertificates": true,
      "AllowInsecureHttp": true,
      "UseEmailSink": true
    }
  }
}
