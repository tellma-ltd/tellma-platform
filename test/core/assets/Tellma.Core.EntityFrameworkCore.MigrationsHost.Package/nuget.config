<?xml version="1.0" encoding="utf-8"?>
<!-- Routes the Tellma packages to the local feed produced by `dotnet pack` (artifacts/pkg at
     the repo root) and everything else to nuget.org. Self-contained so machine-level package
     source mappings cannot interfere with the pack-and-consume CI leg. -->
<configuration>
  <packageSources>
    <clear />
    <add key="tellma-local" value="../../../../artifacts/pkg" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="tellma-local">
      <package pattern="Tellma.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
